# Dashboard data
DATA_CSV_PATH=                  # Optional. Absolute path to ServiceNow CSV export. Uses mock data if unset.

# Dashboard server
DASHBOARD_HOST=0.0.0.0          # Bind host for the Dash server
DASHBOARD_PORT=8050             # Bind port for the Dash server

# Anthropic
ANTHROPIC_API_KEY=             # Required if using Anthropic SDK. sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Default model

# OpenAI
OPENAI_API_KEY=                # Required if using OpenAI SDK. sk-...
OPENAI_MODEL=gpt-4o            # Default model

# MCP
MCP_SERVER_URL=                # MCP server endpoint (if remote)
MCP_AUTH_TOKEN=                # MCP auth token

# Hardware (Raspberry Pi)
GPIO_MODE=BCM                  # BCM or BOARD pin numbering
HARDWARE_ENABLED=false         # Set true on Pi hardware

# Runtime
ENVIRONMENT=local              # local | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
